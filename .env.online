# AIM 线上部署环境变量（用于 docker-compose.online.yml）
# 使用方式：
# docker compose --env-file .env.online -f docker-compose.online.yml up -d

############################
# 基础
############################
DOCKER_HUB_MIRROR=docker.io
SERVICE_PULL_POLICY=always

############################
# 数据库 / 缓存
############################
POSTGRES_USER=aim
POSTGRES_PASSWORD=change-me-strong-postgres-password
POSTGRES_DATABASE=aim
POSTGRES_PORT=5432
REDIS_PORT=6379

# 可选：显式覆盖 DSN（不填则 compose 内自动拼接）
# 注意：这里如果手填，必须是最终值，不能写 ${POSTGRES_USER:-aim} 这种占位表达式
AUTH_POSTGRES_DSN=
USER_POSTGRES_DSN=
CHAT_POSTGRES_DSN=
RAG_POSTGRES_DSN=

############################
# 鉴权
############################
JWT_SECRET=change-me-strong-jwt-secret

############################
# 服务镜像（请改成你自己的仓库地址/版本）
############################
USER_SERVICE_IMAGE=registry.example.com/aim/user-service:latest
AUTH_SERVICE_IMAGE=registry.example.com/aim/auth-service:latest
CHAT_SERVICE_IMAGE=registry.example.com/aim/chat-service:latest
RAG_SERVICE_IMAGE=registry.example.com/aim/rag-service:latest
PARSER_SERVICE_IMAGE=registry.example.com/aim/parser-service:latest
GATEWAY_IMAGE=registry.example.com/aim/gateway:latest
FRONTEND_IMAGE=registry.example.com/aim/frontend:latest

# 可选：监控镜像（不填则使用 compose 默认）
PROMETHEUS_IMAGE=
GRAFANA_IMAGE=

############################
# 对外端口
############################
USER_SERVICE_PORT=9001
AUTH_SERVICE_PORT=9002
CHAT_SERVICE_PORT=9003
RAG_SERVICE_PORT=9004
PARSER_SERVICE_PORT=8000
GATEWAY_PORT=8080
FRONTEND_PORT=5173
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

############################
# Bot / LLM
############################
BOT_DEBUG_LLM_REQUEST=0
BOT_ID=1
BOT2_ID=100001

LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT_SECONDS=30
LLM_INSECURE_SKIP_VERIFY=false
LLM_ENABLE_SEARCH=false
LLM_FORCE_SEARCH=false
LLM_SEARCH_STRATEGY=
LLM_ENABLE_THINKING=

LLM2_BASE_URL=
LLM2_API_KEY=
LLM2_MODEL=qwen3.6-plus
LLM2_TIMEOUT_SECONDS=30
LLM2_INSECURE_SKIP_VERIFY=false
LLM2_ENABLE_SEARCH=true
LLM2_FORCE_SEARCH=true
LLM2_SEARCH_STRATEGY=turbo
LLM2_ENABLE_THINKING=false

LLM_PROVIDER=primary
BOT_CONTEXT_MESSAGES=20
BOT_LLM_TIMEOUT_SECONDS=30
BOT_TASK_TIMEOUT_SECONDS=120

############################
# Summarizer（默认复用 LLM）
############################
SUMMARY_LLM_BASE_URL=
SUMMARY_LLM_API_KEY=
SUMMARY_LLM_MODEL=deepseek-v4-flash
SUMMARY_LLM_TIMEOUT=35s
SUMMARY_LLM_INSECURE_SKIP_VERIFY=false

############################
# Embedding / RAG
############################
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_TIMEOUT_SECONDS=60
EMBEDDING_MAX_RETRIES=2
EMBEDDING_RETRY_BACKOFF_MS=1200
EMBEDDING_INSECURE_SKIP_VERIFY=false

RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=5
RAG_SEARCH_TIMEOUT_SECONDS=80
RAG_DOCUMENT_PROCESS_TIMEOUT_SECONDS=900

RERANK_ENABLED=true
RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
RERANK_API_KEY=
RERANK_MODEL=qwen3-rerank
RERANK_TIMEOUT_SECONDS=15
RERANK_SCORE_THRESHOLD=0.25
RERANK_RECALL_TOP_K=30
RERANK_INSECURE_SKIP_VERIFY=false

############################
# parser-service
############################
VISION_BASE_URL=
VISION_API_KEY=
VISION_MODEL=qwen3.6-plus
VISION_TIMEOUT_SECONDS=90
PARSER_MAX_DESCRIBE_IMAGES=8
PARSER_IMAGE_HEAVY_MIN_IMAGES=4
PARSER_IMAGE_HEAVY_TEXT_CHARS_PER_IMAGE=800
PARSER_ENABLE_LLM_CHUNKING=true
CHUNKER_BASE_URL=
CHUNKER_API_KEY=
CHUNKER_MODEL=deepseek-v4-flash
CHUNKER_TIMEOUT_SECONDS=90
CHUNKER_MAX_CONTENT_CHARS=120000
CHUNKER_FALLBACK_CHARS=1200

############################
# Gateway upload
############################
UPLOAD_MAX_BYTES=629145600

############################
# Grafana
############################
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
