# Copy this file to .env and replace placeholders with local secrets.

MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=aim
MYSQL_USER=aim
MYSQL_PASSWORD=change-me-db-password
JWT_SECRET=change-me-jwt-secret

# Built-in AIM Bot / OpenAI-compatible non-streaming LLM.
# Leave LLM_* empty to disable runtime BotService wiring.
BOT_ID=1
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=replace-with-your-llm-api-key
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=30
