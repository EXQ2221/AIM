# AIM 环境变量模板（复制为 .env 后填写）
# 说明：
# 1) 生产环境请务必替换所有 *PASSWORD / *SECRET / *API_KEY 占位值
# 2) 默认值以 docker-compose.yml 为准，此文件仅提供规范示例

############################
# 镜像与基础设施
############################
DOCKER_HUB_MIRROR=docker.io
GO_IMAGE=m.daocloud.io/docker.io/library/golang:1.25.2-alpine
RUNTIME_IMAGE=m.daocloud.io/docker.io/library/alpine:3.20
NODE_IMAGE=m.daocloud.io/docker.io/library/node:20-alpine
NGINX_IMAGE=m.daocloud.io/docker.io/library/nginx:1.27-alpine
FRONTEND_PORT=5173

POSTGRES_USER=aim
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DATABASE=aim

# 可选：显式覆盖各服务 DSN（不填则 compose 内自动拼接）
AUTH_POSTGRES_DSN=host=postgres user=aim password=change-me-db-password dbname=aim_auth port=5432 sslmode=disable TimeZone=UTC
USER_POSTGRES_DSN=host=postgres user=aim password=change-me-db-password dbname=aim_user port=5432 sslmode=disable TimeZone=UTC
CHAT_POSTGRES_DSN=host=postgres user=aim password=change-me-db-password dbname=aim_chat port=5432 sslmode=disable TimeZone=UTC
RAG_POSTGRES_DSN=host=postgres user=aim password=change-me-db-password dbname=aim_chat port=5432 sslmode=disable TimeZone=UTC

REDIS_ADDR=redis:6379

############################
# 鉴权与会话 Cookie
############################
JWT_SECRET=change-me-jwt-secret
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

############################
# 网关上传能力
############################
UPLOAD_DIR=/app/uploads
UPLOAD_PUBLIC_PREFIX=/uploads
UPLOAD_MAX_BYTES=5242880
KNOWLEDGE_IMPORT_PARSE_TIMEOUT=30m
KNOWLEDGE_IMPORT_PARSE_HTTP_TIMEOUT=30m
KNOWLEDGE_IMPORT_RAG_ADD_TIMEOUT=30m
KNOWLEDGE_IMPORT_WATCH_TIMEOUT=30m
KNOWLEDGE_IMPORT_POLL_INTERVAL=2s
KNOWLEDGE_IMPORT_POLL_RPC_TIMEOUT=5s
KNOWLEDGE_IMPORT_NOTIFY_RPC_TIMEOUT=5s

############################
# 内置 Bot / 主 LLM（provider=primary）
############################
BOT_ID=1
BOT2_ID=100001
BOT_DEBUG_LLM_REQUEST=0

LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=replace-with-your-llm-api-key
LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT_SECONDS=30
LLM_INSECURE_SKIP_VERIFY=false
LLM_ENABLE_SEARCH=false
LLM_FORCE_SEARCH=false
LLM_SEARCH_STRATEGY=
LLM_ENABLE_THINKING=

# 第二模型通道（provider=secondary）
LLM2_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM2_API_KEY=replace-with-your-llm2-api-key
LLM2_MODEL=qwen3.6-plus
LLM2_TIMEOUT_SECONDS=30
LLM2_INSECURE_SKIP_VERIFY=false
LLM2_ENABLE_SEARCH=true
LLM2_FORCE_SEARCH=true
LLM2_SEARCH_STRATEGY=turbo
LLM2_ENABLE_THINKING=false

# 主/次模型选择策略
LLM_PROVIDER=primary
BOT_CONTEXT_MESSAGES=20
BOT_LLM_TIMEOUT_SECONDS=30
BOT_TASK_TIMEOUT_SECONDS=120

############################
# 群聊总结模型（默认复用 LLM）
############################
SUMMARY_LLM_BASE_URL=
SUMMARY_LLM_API_KEY=
SUMMARY_LLM_MODEL=deepseek-v4-flash
SUMMARY_LLM_TIMEOUT=35s
SUMMARY_LLM_INSECURE_SKIP_VERIFY=false

############################
# Embedding / RAG
############################
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_TIMEOUT_SECONDS=60
EMBEDDING_MAX_RETRIES=2
EMBEDDING_RETRY_BACKOFF_MS=1200
EMBEDDING_INSECURE_SKIP_VERIFY=false

RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=5
RAG_SEARCH_TIMEOUT_SECONDS=80
RAG_DOCUMENT_PROCESS_TIMEOUT_SECONDS=900

############################
# Rerank（建议开启）
############################
RERANK_ENABLED=true
RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
RERANK_API_KEY=
RERANK_MODEL=qwen3-rerank
RERANK_TIMEOUT_SECONDS=15
RERANK_SCORE_THRESHOLD=0.25
RERANK_RECALL_TOP_K=30
RERANK_INSECURE_SKIP_VERIFY=false

############################
# parser-service（解析/切分）
############################
VISION_BASE_URL=
VISION_API_KEY=
VISION_MODEL=qwen3.6-plus
VISION_TIMEOUT_SECONDS=90

PARSER_MAX_DESCRIBE_IMAGES=8
PARSER_IMAGE_HEAVY_MIN_IMAGES=4
PARSER_IMAGE_HEAVY_TEXT_CHARS_PER_IMAGE=800
PARSER_ENABLE_LLM_CHUNKING=true

CHUNKER_BASE_URL=https://api.deepseek.com
CHUNKER_API_KEY=replace-with-your-chunker-api-key
CHUNKER_MODEL=deepseek-v4-flash
CHUNKER_TIMEOUT_SECONDS=90
CHUNKER_MAX_CONTENT_CHARS=120000
CHUNKER_FALLBACK_CHARS=1200

############################
# 监控
############################
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
